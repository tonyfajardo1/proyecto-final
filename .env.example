# WARNING:
# Copy this file to .env and fill it with your real group credentials.
# Never commit the real .env file.

# Snowflake connection
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ACCOUNT=abc12345.us-east-1
SNOWFLAKE_HOST=
SNOWFLAKE_PORT=443
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA_RAW=RAW
SNOWFLAKE_SCHEMA_ANALYTICS=ANALYTICS

# Tables created in Snowflake
OBT_SOURCE_TABLE=OBT_TRIPS
OBT_MODEL_TABLE=OBT_TRIPS_MODEL
TRAIN_TABLE=TRAIN_SET
VAL_TABLE=VAL_SET
TEST_TABLE=TEST_SET
TARGET_COLUMN=TOTAL_AMOUNT

# Local runtime settings
BATCH_SIZE=100000
RANDOM_STATE=42
MODEL_PATH=data/processed/price_model.pkl
API_URL=http://127.0.0.1:8000/predict
